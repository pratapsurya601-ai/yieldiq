NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry — frontend error monitoring
# Create the project at sentry.io/yieldiq (project name: yieldiq-frontend)
# and paste the DSN below. SENTRY_AUTH_TOKEN is needed at build time for
# source map upload (set in Vercel env, not local).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=yieldiq
SENTRY_PROJECT=yieldiq-frontend
