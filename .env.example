# YieldIQ --- Environment Variables
# Copy this file to .env and fill in your values.
# On Streamlit Cloud: add these in App Settings > Secrets
# =============================================================

# -- Data Sources ---------------------------------------------
# Finnhub API key (required for live prices + analyst data)
# Get free key at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# -- AI Chat (optional -- app works without these) ------------
# Google Gemini API key (preferred AI backend)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Groq API key (fallback if Gemini unavailable)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# -- Admin Access ---------------------------------------------
# Set to 1 to enable admin dashboard in the sidebar
# Leave empty or 0 in production for regular users
YIELDIQ_ADMIN=0

# -- Batch Mode -----------------------------------------------
# Set to 1 when running the overnight screener batch job
# Disables rate-limit sleeps and enables bulk fetching
YIELDIQ_BATCH_MODE=0

# -- Google Sheets Export (optional) --------------------------
# JSON string of Google service account credentials
# OR path to the credentials JSON file (use one, not both)
# Leave empty to disable Sheets export feature
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_CREDENTIALS_FILE=

# -- API Optimizer (optional, dev tool only) ------------------
# Anthropic API key for the API usage optimizer dashboard
# Only needed if running streamlit_api_optimizer.py
ANTHROPIC_API_KEY=
